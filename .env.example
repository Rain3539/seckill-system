# ============================================================
# 秒杀系统 - 环境配置模板（示例）
# 
# 使用说明：
#   1. 复制此文件并改名为 .env
#   2. 根据需要修改参数值
#   3. Docker Compose 会自动读取 .env 文件
# ============================================================

# ── 数据库配置 ──────────────────────────────────────────────
# MySQL 主库 root 密码
MYSQL_ROOT_PASSWORD=root123

# MySQL 业务用户密码（用于写操作）
MYSQL_PASSWORD=seckill123

# MySQL 数据库名
MYSQL_DATABASE=seckill_db

# MySQL 业务用户名
MYSQL_USER=seckill

# MySQL 从库只读用户密码
SLAVE_PASSWORD=seckill_ro123

# ── Redis 配置 ──────────────────────────────────────────────
# Redis 访问密码
REDIS_PASSWORD=redis123

# ── JWT 配置 ────────────────────────────────────────────────
# ⚠️ 重要：JWT 密钥必须至少 32 字节（256 bits）
# 当前长度：64 字节（512 bits），安全等级：高
# 支持的签名算法：HS256（推荐）、HS384、HS512
#
# 密钥生成建议（使用强随机字符串）：
#   在线工具：https://www.base64encode.org/
#   Linux/Mac: head -c 32 /dev/urandom | base64
#   PowerShell: [Convert]::ToBase64String([System.Security.Cryptography.RNGCryptoServiceProvider]::new().GenerateBytes(32))
JWT_SECRET=seckill-jwt-secret-key-2024-very-long-string-12345678901234567890

# ── 实例配置 ────────────────────────────────────────────────
# 后端实例标识（用于日志和监控中区分不同实例）
INSTANCE_ID=local

# ── 时区设置 ────────────────────────────────────────────────
# 数据库和应用时区（影响时间戳、日志等）
TZ=Asia/Shanghai
