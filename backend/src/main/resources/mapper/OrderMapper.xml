<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seckill.mapper.OrderMapper">

    <resultMap id="OrderRM" type="com.seckill.model.entity.Order">
        <id     property="id"          column="id"/>
        <result property="orderNo"     column="order_no"/>
        <result property="userId"      column="user_id"/>
        <result property="productId"   column="product_id"/>
        <result property="productType" column="product_type"/>
        <result property="productName" column="product_name"/>
        <result property="quantity"    column="quantity"/>
        <result property="unitPrice"   column="unit_price"/>
        <result property="amount"      column="amount"/>
        <result property="status"      column="status"/>
        <result property="createdAt"   column="created_at"/>
        <result property="updatedAt"   column="updated_at"/>
    </resultMap>

    <select id="findByOrderNo" resultMap="OrderRM">
        SELECT * FROM `order` WHERE order_no = #{orderNo}
    </select>

    <select id="findByUserId" resultMap="OrderRM">
        SELECT * FROM `order` WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="countSeckillOrder" resultType="int">
        SELECT COUNT(1) FROM `order`
        WHERE user_id = #{userId}
          AND product_id = #{productId}
          AND product_type = 1
          AND status != 2
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `order`
            (order_no, user_id, product_id, product_type, product_name,
             quantity, unit_price, amount, status)
        VALUES
            (#{orderNo}, #{userId}, #{productId}, #{productType}, #{productName},
             #{quantity}, #{unitPrice}, #{amount}, #{status})
    </insert>

    <update id="updateStatus">
        UPDATE `order` SET status = #{status} WHERE id = #{id}
    </update>

</mapper>
