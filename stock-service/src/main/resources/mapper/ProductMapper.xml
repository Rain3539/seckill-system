<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seckill.stock.mapper.ProductMapper">

    <resultMap id="ProductRM" type="com.seckill.stock.model.entity.Product">
        <id     property="id"          column="id"/>
        <result property="name"        column="name"/>
        <result property="description" column="description"/>
        <result property="price"       column="price"/>
        <result property="stock"       column="stock"/>
        <result property="imageUrl"    column="image_url"/>
        <result property="status"      column="status"/>
        <result property="createdAt"   column="created_at"/>
        <result property="updatedAt"   column="updated_at"/>
    </resultMap>

    <select id="findById"     resultMap="ProductRM">SELECT * FROM product WHERE id = #{id}</select>
    <select id="findAllOnSale" resultMap="ProductRM">
        SELECT * FROM product WHERE status = 1 ORDER BY id DESC
    </select>
    <update id="decreaseStock">
        UPDATE product SET stock = stock - #{quantity}
        WHERE id = #{id} AND stock >= #{quantity}
    </update>
    <update id="increaseStock">
        UPDATE product SET stock = stock + #{quantity} WHERE id = #{id}
    </update>
</mapper>
